rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isValidUser(data) {
      return data.keys().hasAll(["uid", "email", "name", "role"]) && 
             data.keys().size() == 4 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 100 &&
             data.role in ["admin", "user"];
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isSignedIn() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming()) && incoming().uid == request.auth.uid &&
                    (incoming().role == "user" || (incoming().role == "admin" && request.auth.token.email.matches('.*@ssdi\\.com$')))) ||
                    (isAdmin() && isValidId(userId) && isValidUser(incoming()) && incoming().uid == userId);
      allow update: if isAdmin() && isValidUser(incoming());
      allow delete: if isAdmin() && isValidId(userId);
    }

    function isValidAsset(data) {
      return data.keys().hasAll(["name", "category", "status", "purchaseDate", "value", "location", "owner", "lastUpdated"]) &&
             data.keys().size() == 8 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.status in ["Active", "Maintenance", "Deprecated", "Disposed"] &&
             data.purchaseDate is string && data.purchaseDate.size() <= 50 &&
             data.value is number &&
             data.location is string && data.location.size() <= 200 &&
             data.owner is string && data.owner.size() <= 100 &&
             data.lastUpdated is string && data.lastUpdated.size() <= 50;
    }

    match /assets/{assetId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(assetId) && isValidAsset(incoming());
      allow update: if isAdmin() && isValidId(assetId) && isValidAsset(incoming());
      allow delete: if isAdmin() && isValidId(assetId);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(["timestamp", "user", "action", "details"]) &&
             data.keys().size() == 4 &&
             data.timestamp is string && data.timestamp.size() <= 50 &&
             data.user is string && data.user.size() <= 100 &&
             data.action is string && data.action.size() <= 100 &&
             data.details is string && data.details.size() <= 1000;
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidId(logId) && isValidAuditLog(incoming());
      allow update: if false; // Audit logs should not be mutated
      allow delete: if false; // For compliance, deleting logs not allowed
    }

    function isValidNotification(data) {
      return data.keys().hasAll(["timestamp", "message", "isRead", "type"]) &&
             data.keys().size() == 4 &&
             data.timestamp is string && data.timestamp.size() <= 50 &&
             data.message is string && data.message.size() <= 500 &&
             data.isRead is bool &&
             data.type in ["info", "warning", "success", "alert"];
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(notifId) && isValidNotification(incoming());
      allow update: if isSignedIn() && isValidId(notifId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['isRead']) &&
                    incoming().isRead is bool;
      allow delete: if isAdmin() && isValidId(notifId);
    }
  }
}
